#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/jeremy/ontologies/2026/0/untitled-ontology-30/toAgent
:toAgent rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Fee ;
         rdfs:range :Agent .


###  http://www.semanticweb.org/jeremy/ontologies/2026/0/untitled-ontology-30/toRoom
:toRoom rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf owl:topObjectProperty ;
        rdfs:domain :Move ;
        rdfs:range :Room .


#################################################################
#    Data properties
#################################################################

###  http://localhost:5001/ontologies/maze.ttl#requiresNoSubscription
:requiresNoSubscription rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf owl:topDataProperty ;
                        rdfs:domain :Fee ;
                        rdfs:range xsd:boolean ;
                        rdfs:comment "Indicates whether the fee is only to be paid if the agent does not have a subscription." .


###  http://www.semanticweb.org/jeremy/ontologies/2026/0/untitled-ontology-30/amount
:amount rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:domain :Fee ;
        rdfs:range xsd:positiveInteger ;
        rdfs:comment "The amount to pay for a fee" .



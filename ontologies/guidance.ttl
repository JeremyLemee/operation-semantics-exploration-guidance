#################################################################

###  http://localhost:5001/ontologies/guidance.ttl/hasDangerCause
:hasDangerCause rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain :NonExplorableOperation ;
                rdfs:range :DangerCause .


###  http://localhost:5001/ontologies/guidance.ttl/hasOutcome
:hasOutcome rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Operation ;
            rdfs:range :Outcome .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2002/07/owl#topDataProperty
owl:topDataProperty rdfs:domain :DangerCause ;
                    rdfs:range xsd:string .


#################################################################

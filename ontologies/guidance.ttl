#################################################################

###  http://localhost:5001/ontologies/guidance.ttl#Outcome
:Outcome rdf:type owl:Class .


###  http://localhost:5001/ontologies/guidance.ttl/DangerCause
:DangerCause rdf:type owl:Class .


###  http://localhost:5001/ontologies/guidance.ttl/ExplorableOperation
:ExplorableOperation rdf:type owl:Class ;
                     rdfs:subClassOf :Operation ;
                     owl:disjointWith :NonExplorableOperation ;
                     rdfs:comment "The operation is explorable." .


###  http://localhost:5001/ontologies/guidance.ttl/NonExplorableOperation
:NonExplorableOperation rdf:type owl:Class ;
                        rdfs:subClassOf :Operation ;
                        rdfs:comment "The operation is not explorable." .


###  http://localhost:5001/ontologies/guidance.ttl/Operation
:Operation rdf:type owl:Class .


